# GitHub bot identity (must match gh auth identity used by this runtime)
AGENT_GITHUB_USERNAME=your-bot-username

# Comma-separated list of GitHub usernames allowed to trigger feedback handling via @mention.
# Leave empty to allow any user (not recommended for production).
AUTHORIZED_USERS=maintainer1,maintainer2

# Runtime directories
# PROJECTS_DIR stores persistent repo clones of managed repositories.
PROJECTS_DIR=~/projects
# RUNTIME_DIR stores transient git worktrees used by workers.
# Keep this outside the orchestration repo.
RUNTIME_DIR=~/projects/_worktrees
STATE_DIR=./state
LOG_DIR=./logs

# Agent backend configuration
AGENT_BACKEND=cline
AGENT_CMD=cline
AGENT_MODEL=codex-5.3
# Recommended even if you authenticate Cline via `cline auth`:
# workers export these as compatibility env hints (OPENAI_BASE_URL / OPENAI_API_KEY).
AGENT_BASE_URL=https://litellm.example.com/v1
AGENT_API_KEY=replace-me
# Optional for self-signed/internal CA chains used by Node-based CLIs:
# NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/homelab-ca.crt

# install.sh default behavior: installs Cline CLI via `npm install -g cline`
# Requires Node.js >= 20 on the VM.
# Optional: pin a specific Cline version
# CLINE_VERSION=latest

# Optional tuning flags for CLI compatibility.
# Defaults are auto-detected from your installed `cline --help`.
# AGENT_INPUT_MODE=file
# AGENT_SUBCOMMAND=run
# AGENT_MODEL_FLAG=--model
# AGENT_BASE_URL_FLAG=--base-url
# AGENT_API_KEY_FLAG=--api-key
# AGENT_PROMPT_FILE_FLAG=--prompt-file
# AGENT_NON_INTERACTIVE_FLAG=--non-interactive
# AGENT_EXTRA_ARGS=--some-flag value

# Worker controls
ISSUE_TIMEOUT_MINUTES=45
FEEDBACK_TIMEOUT_MINUTES=35
MIN_AVAILABLE_MB=512
MAX_OPEN_AGENT_PRS=10
DAILY_FEEDBACK_LIMIT=30
UNASSIGN_ON_NOOP=true
INSTALL_CRON=true

# Managed repository configuration
CONFIG_FILE=./configs/repos.json
